{
  "workbench.sideBar.location": "left",
  "css.lint.unknownAtRules": "ignore",
  "sonarlint.rules": {
    "css:S4662": {
      "level": "off"
    },
    "javascript:S6747": {
      "level": "off"
    },
    "javascript:S7764": {
      "level": "off"
    },
    "javascript:S6772": {
      "level": "off"
    },
    "javascript:S3776": {
      "level": "off"
    }
  },
  "git.ignoreLimitWarning": true,

  // ─── Git: não adicionar os ~44 repos aninhados (9 worktrees + _references/* +
  // _mono_repo/* + _ideia/_tasks/.agents) ao Source Control. Era a causa do
  // "validando muito": um git status + watcher por repo. Só o repo raiz fica. ───
  "git.autoRepositoryDetection": false,
  "git.repositoryScanMaxDepth": 0,
  "git.detectSubmodules": false,
  "git.autofetch": false,
  "git.autorefresh": true,

  // ─── Performance: não seguir o symlink de node_modules criado pelas worktrees ───
  // As worktrees em .worktrees/ apontam node_modules para o checkout principal;
  // sem isto a busca atravessa o symlink mesmo com node_modules excluído.
  "search.followSymlinks": false,

  // ─── TypeScript server (monorepo grande: ~6,6k arquivos rastreados, Next.js 16) ───
  "js/ts.tsserver.maxMemory": 4096,
  "js/ts.tsserver.automaticTypeAcquisition.enabled": true,
  "js/ts.tsc.autoDetect": "off",
  "npm.autoDetect": "off",
  // O tsserver tem o próprio watcher (independente de files.watcherExclude).
  // excludeDirectories evita que ele vigie as árvores pesadas.
  "js/ts.tsserver.watchOptions": {
    "excludeDirectories": [
      "**/node_modules",
      "**/.next",
      "**/.build",
      "**/dist",
      "**/coverage",
      "**/.worktrees"
    ]
  },

  // Para esconder os diretórios gerados da árvore do Explorer, descomente:
  // "files.exclude": {
  //   "**/.worktrees": true,
  //   "**/coverage": true,
  //   "**/dist": true,
  //   "**/.build": true,
  //   "**/.next": true,
  //   "**/_references": true,
  //   "**/_mono_repo": true,
  //   "**/_tasks": true,
  //   "**/omniroute-*.tgz": true
  // },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/.build/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/out/**": true,
    "**/coverage/**": true,
    "**/.coverage/**": true,
    "**/.nyc_output/**": true,
    "**/.cache/**": true,
    "**/.turbo/**": true,
    "**/.swc/**": true,
    "**/.stryker-tmp/**": true,
    "**/stryker-output-*/**": true,
    "**/playwright-report/**": true,
    "**/test-results/**": true,
    "**/.worktrees/**": true,
    "**/.claude/worktrees/**": true,
    "**/electron/**": true,
    "**/_references/**": true,
    "**/_mono_repo/**": true,
    "**/_tasks/**": true,
    "**/logs/**": true,
    "**/*.tgz": true,
    "**/*.tsbuildinfo": true,
    "**/OmniRoute-*/**": true,
    "**/*-merge-*/**": true,
    "**/*-worktree-*/**": true,
    "**/*-issues-*/**": true,
    "**/*-reorg*/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.build": true,
    "**/dist": true,
    "**/build": true,
    "**/out": true,
    "**/coverage": true,
    "**/.coverage": true,
    "**/.nyc_output": true,
    "**/.cache": true,
    "**/.turbo": true,
    "**/.swc": true,
    "**/.stryker-tmp": true,
    "**/stryker-output-*": true,
    "**/playwright-report": true,
    "**/test-results": true,
    "**/.worktrees": true,
    "**/.claude/worktrees": true,
    "**/electron": true,
    "**/_references": true,
    "**/_mono_repo": true,
    "**/_tasks": true,
    "**/logs": true,
    "**/*.tgz": true,
    "**/*.tsbuildinfo": true,
    "**/package-lock.json": true,
    "**/OmniRoute-*": true,
    "**/*-merge-*": true,
    "**/*-worktree-*": true,
    "**/*-issues-*": true,
    "**/*-reorg*": true
  },
  "terminal.integrated.env.linux": {
    "PATH": "${workspaceFolder}/.venv/bin:${workspaceFolder}/venv/bin:${workspaceFolder}/bin:${workspaceFolder}/node_modules/.bin:${workspaceFolder}/vendor/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games:/usr/local/games:/usr/lib/wsl/lib",
    "PUPPETEER_SKIP_DOWNLOAD": "true",
    "PHP_CS_FIXER_IGNORE_ENV": "1",
    "ESLINT_USE_FLAT_CONFIG": "true",
    "WORKSPACE_FOLDER": "${workspaceFolder}"
  },
  "terminal.integrated.env.windows": {
    "PATH": "${workspaceFolder}\\bin;${workspaceFolder}\\node_modules\\.bin;${workspaceFolder}\\.venv\\Scripts;${workspaceFolder}\\venv\\Scripts;${workspaceFolder}\\vendor\\bin;${env:LOCALAPPDATA}\\nvm;C:\\nvm4w\\nodejs;C:\\Program Files\\Git\\cmd;C:\\Program Files\\Git\\usr\\bin;C:\\laragon\\bin\\mysql\\mysql-8.4.3-winx64\\bin;${env:LOCALAPPDATA}\\Programs\\Ollama;${env:PATH}",
    "PUPPETEER_SKIP_DOWNLOAD": "true",
    "PHP_CS_FIXER_IGNORE_ENV": "1",
    "ESLINT_USE_FLAT_CONFIG": "true",
    "WORKSPACE_FOLDER": "${workspaceFolder}"
  },
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    },
    "Short PowerShell": {
      "source": "PowerShell",
      "args": ["-NoExit", "-Command", "function prompt { \"[$((Get-Item .).Name)]> \" }"],
      "icon": "terminal-powershell"
    },
    "PowerShell 7": {
      "path": "${env:LOCALAPPDATA}\\Microsoft\\WindowsApps\\pwsh.exe",
      "icon": "terminal-powershell"
    },
    "Short PowerShell 7": {
      "path": "${env:LOCALAPPDATA}\\Microsoft\\WindowsApps\\pwsh.exe",
      "args": [
        "-NoExit",
        "-Command",
        "function prompt { Write-Host '[' -NoNewline -ForegroundColor DarkGray; Write-Host (Split-Path -Leaf (Get-Location)) -NoNewline -ForegroundColor Cyan; Write-Host ']> ' -NoNewline -ForegroundColor DarkGray; return ' ' }"
      ],
      "icon": "terminal-powershell"
    },
    "Oh My Posh": {
      "path": "${env:LOCALAPPDATA}\\Microsoft\\WindowsApps\\pwsh.exe",
      "args": [
        "-NoExit",
        "-Command",
        "$init = $null; foreach ($candidate in @('${workspaceFolder}/scripts/OhMyPoshInit.ps1','${workspaceFolder}/node_modules/@dimaslanjaka/eslint-base-config/scripts/OhMyPoshInit.ps1')) { if (Test-Path $candidate) { $init = $candidate; break } }; if ($init) { & $init } else { oh-my-posh init pwsh | Invoke-Expression }"
      ],
      "icon": "terminal-powershell"
    },
    "Command Prompt": {
      "path": ["${env:windir}\\Sysnative\\cmd.exe", "${env:windir}\\System32\\cmd.exe"],
      "args": [],
      "icon": "terminal-cmd"
    },
    "Short Command Prompt": {
      "path": ["${env:windir}\\System32\\cmd.exe"],
      "args": ["/k", "prompt $p$_$g"],
      "icon": "terminal-cmd"
    },
    "Git Bash": {
      "source": "Git Bash"
    },
    "Cygwin": {
      "path": "C:\\cygwin64\\bin\\bash.exe",
      "args": ["--login", "-i"],
      "env": {
        "CHERE_INVOKING": "1"
      }
    }
  },
  "terminal.integrated.fontFamily": "MesloLGM Nerd Font",
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "eslint.debug": true,
  "eslint.enable": true,
  "eslint.format.enable": false,
  "eslint.probe": [
    "astro",
    "civet",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "mdx",
    "vue",
    "markdown",
    "json",
    "jsonc",
    "css",
    "glimmer-js",
    "glimmer-ts",
    "svelte",
    "nunjucks"
  ],
  "eslint.run": "onSave",
  "eslint.useESLintClass": true,
  "eslint.useRealpaths": true,
  "eslint.validate": [
    "astro",
    "civet",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "mdx",
    "vue",
    "markdown",
    "json",
    "jsonc",
    "css",
    "glimmer-js",
    "glimmer-ts",
    "svelte",
    "nunjucks"
  ],
  "eslint.useFlatConfig": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never",
    "source.fixAll.ts": "never",
    "source.addMissingImports.ts": "never",
    "source.removeUnused.ts": "never",
    "source.removeUnusedImports": "never",
    "source.sort.json": "never",
    "source.sortImports": "never"
  },
  "code-runner.executorMap": {
    "javascript": "node --no-warnings=ExperimentalWarning",
    "typescript": "node --no-warnings=ExperimentalWarning --inspect node_modules/tsx/dist/cli.mjs"
  },
  "code-runner.executorMapByGlob": {
    "*.electron.js": "cross-env-shell NODE_ENV=development electron -r ts-node/register",
    "*.py": "py -u",
    "*.test.{js,ts}": "node --import tsx/esm --test",
    "*.test.cjs": "node --import tsx/esm --test",
    "*.test.mjs": "node --import tsx/esm --test",
    "*Test.php": "phpunit --debug --testdox --colors=always",
    "electron-*.ts": "cross-env-shell NODE_ENV=development electron -r ts-node/register",
    "rollup.*.{js,cjs,mjs,ts}": "rollup -c",
    "*.sh": "sh",
    "*.bat": "cmd /c",
    "*.cmd": "cmd /c"
  }
}
