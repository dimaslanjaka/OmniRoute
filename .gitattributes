# Normalize line endings
* text working-tree-encoding=UTF-8

# Shell scripts
*.sh text eol=lf
.husky/* text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# JavaScript / CommonJS / ESM
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf

# TypeScript
*.ts text eol=lf
*.mts text eol=lf
*.cts text eol=lf
*.tsx text eol=lf

# Configs
*.json text eol=lf
*.jsonc text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.zip binary
*.7z binary
*.gz binary
*.tar binary
*.rar binary
*.pdf binary
*.tgz binary
*.mp3 binary
*.mp4 binary
*.icns binary
